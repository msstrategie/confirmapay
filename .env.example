# Clé secrète Django — générer une vraie clé aléatoire en production
SECRET_KEY=changez-moi-avec-une-vraie-cle-aleatoire

# Mode debug — toujours False en production
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# Connexion PostgreSQL
DATABASE_URL=postgres://utilisateur@localhost/confirmapay
DB_NAME=confirmapay
DB_USER=votre_utilisateur_postgres
DB_PASSWORD=votre_mot_de_passe
DB_HOST=localhost
DB_PORT=5432
